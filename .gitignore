# ChromaDB data — not committed (regenerable, large)
data/chroma/
data/chroma.bak/
data/ingest_history.jsonl
data/eval_history.jsonl
data/graph.db
data/graph.db-*
data/blocks.db
data/blocks.db-*
data/quarantine.db
data/quarantine.db-*
data/brain_export.md
data/events.db
data/events.db-*

# Env
.env
.env.local

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/
*.egg-info/

# IDE
.vscode/
.idea/
.DS_Store

# OS
Thumbs.db

# Runtime state (PID files, logs) — generated at runtime
data/*.pid
data/*.log
data/watcher_state.json

# Session notes — written by the watcher for KAIROS / DuckBot's memory
# pipeline. These contain private file paths and conversation context that
# should NOT be committed. The watcher ingests them automatically; the git
# repo stays clean.
memory/

# macOS Spotlight duplicate-name artifacts (e.g. "foo 2.md")
# Created when multiple edits land on the same filename before fsync resolves.
**/* 2.md
**/* 2.sh
**/* 2.py

# Backup archives and log files — never committed
data/backups/
data/logs/
