# DuckBot RAG + Memory - environment configuration
# Copy this to .env and fill in the keys for whichever providers you want enabled.

# ============================================================================
# Embedding providers (at least ONE is required)
# ============================================================================
# DUCKBOT_EMBEDDING selects the active provider. Default: auto-detect.
# Options: "openai" | "minimax" | "lmstudio" | "local"
#
# Auto-detect order when DUCKBOT_EMBEDDING is unset:
#   1. OPENAI_API_KEY set       -> openai
#   2. MINIMAX_API_KEY set      -> minimax
#   3. LM Studio reachable      -> lmstudio
#   4. sentence-transformers    -> local
#   5. none                     -> error

# --- OpenAI (primary cloud, 1536d) ---
OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- MiniMax (cloud, 1536d) ---
# MINIMAX_API_KEY=sk-minimax-...
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_EMBED_MODEL=text-embedding-01

# --- LM Studio (local, dim from model) ---
# LMSTUDIO_URL=http://127.0.0.1:1234/v1
# LMSTUDIO_MODEL=text-embedding-nomic-embed-text-v1.5
# LMSTUDIO_API_KEY=lm-studio  # or use LMSTUDIO_KEY / LM_API_TOKEN
# LMSTUDIO_EMBED_DIM=768

# --- sentence-transformers (offline, no API) ---
# pip install sentence-transformers
# DUCKBOT_EMBEDDING=local

# ============================================================================
# OpenClaw integration (paths the cron will read from)
# ============================================================================
OPENCLAW_WORKSPACE=/Users/duckets/.openclaw/workspace
OPENCLAW_MEMORY=/Users/duckets/.openclaw/workspace/memory

# ============================================================================
# Cron / scheduling
# ============================================================================
# Used by scripts/cron.sh to find a working Python when cron has no PATH.
# PYTHON_BIN=/Users/duckets/Desktop/duckbot-rag-memory/.venv/bin/python
